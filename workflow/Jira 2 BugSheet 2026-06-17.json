    {
      "parameters": {
        "jsCode": "return $input.all().map((item) => {\n  let aiRaw = item.json.output || item.json.text || \"\";\n  \n  let parsedAi = { description: \"\", type: \"\", area: \"\" };\n  \n  if (aiRaw) {\n    try {\n      // Очищаем от возможных markdown тегов ```json ... ```\n      aiRaw = aiRaw.replace(/```json|```/gi, '').trim();\n      \n      // Превращаем текст в объект\n      parsedAi = JSON.parse(aiRaw);\n    } catch (e) {\n      // Если ИИ выдал просто текст, сохраняем его в описание\n      parsedAi.description = aiRaw;\n    }\n  }\n\n  // Возвращаем исходный объект, но ДОБАВЛЯЕМ в него чистые поля ai_fields\n  return {\n    json: {\n      ...item.json,\n      ai_fields: {\n        description: parsedAi.description || \"\",\n        type: parsedAi.type || \"\",\n        area: parsedAi.area || \"\"\n      }\n    }\n  };\n});"
      },
