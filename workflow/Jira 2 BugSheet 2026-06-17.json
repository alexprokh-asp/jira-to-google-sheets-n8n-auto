    {
      "parameters": {
        "jsCode": "let item = $input.item; // Берем строго один текущий элемент цикла\nlet aiRaw = item.json.output || item.json.text || \"\";\nlet parsedAi = { description: \"\", type: \"\", area: \"\" };\n\nif (aiRaw) {\n  try {\n    aiRaw = aiRaw.replace(/```json|```/gi, '').trim();\n    parsedAi = JSON.parse(aiRaw);\n  } catch (e) {\n    parsedAi.description = aiRaw;\n  }\n}\n\nconst fields = item.json.fields || (item.json.input ? item.json.input.fields : {});\nconst issueKey = item.json.key || (item.json.input ? item.json.input.key : \"\");\nconst fallbackArea = fields.fixVersions && fields.fixVersions.length > 0 ? fields.fixVersions[0].name : \"\";\n\n// ДОСТАЕМ SEVERITY: проверяем, есть ли поле customfield_10172 и берем оттуда value\nconst severityValue = fields.customfield_10172 ? fields.customfield_10172.value : \"\";\n\nreturn {\n  json: {\n    \"Number\": issueKey,\n    \"Date\": fields.created ? fields.created.substring(0, 10) : \"\",\n    \"Area\": parsedAi.area || fallbackArea,\n    \"Bugs Name\": fields.summary || \"\",\n    \"Desctiption\": parsedAi.description || fields.summary,\n    \"Type\": parsedAi.type || \"Functional\",\n    \"Prioriy\": fields.priority ? fields.priority.name : \"\",\n    \"Severity\": severityValue, // Сюда теперь прилетит \"Major\"\n    \"State\": fields.status ? fields.status.name : \"\",\n    \"Assign\": fields.assignee ? fields.assignee.displayName : \"Unassigned\",\n    \"Jira Ticket\": `https://your-domain.atlassian.net/browse/${issueKey}`,\n    \"Start Date\": \"\",\n    \"Finish Date\": fields.resolutiondate ? fields.resolutiondate.substring(0, 10) : \"\",\n    \"Notes\": \"\"\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        640,
        -112
      ],
      "id": "1a3e5c66-0842-491f-be56-59321c32755f",
